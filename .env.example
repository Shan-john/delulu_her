# ── Delulu Her — Environment Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values.
# Lines starting with # are comments.

# ── LLM / Model ─────────────────────────────────────────────────────────────
# Path to TinyLlama 1.1B Q4_K_M GGUF model file.
# Download from: https://huggingface.co/TheBloke/TinyLlama-1.1B-Chat-v1.0-GGUF
# Filename: tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
MODEL_PATH=./models/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
MODEL_CONTEXT_LENGTH=2048
MODEL_THREADS=4                 # CPU threads to use (4 for RPi5, 8+ for laptop)
MODEL_GPU_LAYERS=0              # 0 = CPU only (RPi compatible)

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=delulu_her

# ── Audio ────────────────────────────────────────────────────────────────────
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_CHUNK_DURATION=0.5        # seconds per audio chunk
AUDIO_SILENCE_THRESHOLD=0.01    # RMS energy threshold for VAD
AUDIO_SPEECH_BUFFER_SEC=5       # seconds of audio to buffer before STT
WHISPER_MODEL=tiny               # tiny, base, small (tiny = ~75MB)
TEXT_INPUT_MODE=false            # Set to true to use keyboard instead of mic

# ── Piper TTS ────────────────────────────────────────────────────────────────
# Download Piper from: https://github.com/rhasspy/piper/releases
# Voice model from: https://huggingface.co/rhasspy/piper-voices
PIPER_EXECUTABLE=./piper/piper   # path to piper binary
PIPER_VOICE_MODEL=./piper/voices/en_US-amy-medium.onnx
PIPER_VOICE_CONFIG=./piper/voices/en_US-amy-medium.onnx.json

# ── Email (IMAP) ─────────────────────────────────────────────────────────────
# Set EMAIL_ENABLED=false to disable email integration entirely.
EMAIL_ENABLED=false
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_ADDRESS=your.email@gmail.com
EMAIL_PASSWORD=your_app_password  # Use Gmail App Password, not account password
EMAIL_CHECK_INTERVAL_MIN=10       # How often to poll for new email (minutes)
EMAIL_MAX_FETCH=5                 # Max emails to fetch per poll

# ── Personality & Consciousness ───────────────────────────────────────────────
AI_NAME=Delulu
THOUGHT_LOOP_MIN_SEC=30          # Min seconds between self-initiated thoughts
THOUGHT_LOOP_MAX_SEC=120         # Max seconds between self-initiated thoughts
SPEAK_THOUGHT_PROBABILITY=0.25   # Chance of speaking a thought aloud (0-1)
CURIOSITY_DECAY_RATE=0.05        # How fast curiosity fades without conversation

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                   # DEBUG, INFO, WARNING, ERROR
